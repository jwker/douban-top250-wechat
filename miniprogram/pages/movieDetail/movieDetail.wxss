.container {
  padding: 20rpx;
}

.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}

.movie-detail {
  background: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
}

.header {
  display: flex;
  margin-bottom: 30rpx;
}

.poster {
  width: 240rpx;
  height: 320rpx;
  border-radius: 12rpx;
  background: #eee;
}

.header-info {
  flex: 1;
  margin-left: 30rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.rating {
  font-size: 48rpx;
  font-weight: bold;
  color: #ff6b6b;
}

.rating-label {
  font-size: 24rpx;
  color: #ff6b6b;
  margin-left: 4rpx;
}

.meta {
  font-size: 26rpx;
  color: #666;
  margin-top: 8rpx;
}

.action-bar {
  display: flex;
  margin-bottom: 30rpx;
  padding: 20rpx 0;
  border-top: 1rpx solid #f0f0f0;
  border-bottom: 1rpx solid #f0f0f0;
}

.btn-favorite, .btn-share {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border: none;
  border-radius: 44rpx;
  margin: 0 10rpx;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #666;
}

.btn-favorite.active {
  background: #fff3f3;
  color: #ff6b6b;
}

.icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
  display: block;
}

.content {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.tags {
  display: flex;
  flex-wrap: wrap;
}

.tag {
  background: #f0f0f0;
  color: #666;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
}

.quote {
  font-size: 28rpx;
  color: #666;
  font-style: italic;
  line-height: 1.6;
}

.rank-display {
  display: flex;
  align-items: baseline;
}

.rank-number {
  font-size: 72rpx;
  font-weight: bold;
  color: #ff6b6b;
}

.rank-label {
  font-size: 28rpx;
  color: #999;
  margin-left: 12rpx;
}