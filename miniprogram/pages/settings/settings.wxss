.container {
  padding: 20rpx;
}

.section {
  background: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-header {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.setting-label {
  display: flex;
  flex-direction: column;
}

.label-text {
  font-size: 28rpx;
  color: #333;
}

.label-hint {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.time-value {
  display: flex;
  align-items: center;
  color: #ff6b6b;
  font-size: 28rpx;
  font-weight: bold;
}

.arrow {
  font-size: 32rpx;
  margin-left: 8rpx;
}

.btn-save {
  margin-top: 30rpx;
  background: #fff;
  border: 2rpx solid #ff6b6b;
  color: #ff6b6b;
  border-radius: 44rpx;
  padding: 20rpx;
  font-size: 28rpx;
}

.update-info {
  background: #f9f9f9;
  border-radius: 8rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.info-text {
  font-size: 24rpx;
  color: #666;
  display: block;
  line-height: 1.6;
}

.btn-update {
  background: linear-gradient(135deg, #ff6b6b, #ff4757);
  color: #fff;
  border: none;
  border-radius: 44rpx;
  padding: 24rpx;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.about-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.about-item:last-child {
  border-bottom: none;
}

.about-label {
  font-size: 28rpx;
  color: #666;
}

.about-value {
  font-size: 28rpx;
  color: #333;
}