<view class="container">
  <!-- 日期选择器 -->
  <view class="date-picker-section">
    <picker mode="date" value="{{selectedDate}}" bindchange="onDateChange">
      <view class="picker-display">
        <text class="picker-label">选择日期</text>
        <view class="picker-value">
          <text>{{selectedDate}}</text>
          <text class="picker-arrow">▼</text>
        </view>
      </view>
    </picker>

    <view class="quick-dates">
      <text class="quick-label">快速选择:</text>
      <view class="quick-btns">
        <text class="quick-btn {{selectedDate === item ? 'active' : ''}}" wx:for="{{availableDates}}" wx:key="index" bindtap="onQuickSelect" data-date="{{item}}">{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 电影列表 -->
  <view class="movie-list">
    <view class="list-header">
      <text class="list-title">{{selectedDate}} 榜单</text>
      <text class="list-count">{{movies.length}}部</text>
    </view>

    <view class="loading" wx:if="{{loading}}">
      <text>加载中...</text>
    </view>

    <view class="empty-tip" wx:if="{{!loading && movies.length === 0}}">
      <text>该日期暂无榜单数据</text>
    </view>

    <view class="movie-item" wx:for="{{movies}}" wx:key="_id" bindtap="goToMovieDetail" data-id="{{item._id}}">
      <view class="movie-rank {{item.rank <= 10 ? 'top10' : ''}}">{{item.rank}}</view>
      <image class="movie-poster" src="{{item.poster}}" mode="aspectFill"></image>
      <view class="movie-info">
        <text class="movie-title">{{item.title}}</text>
        <text class="movie-meta">{{item.director}}</text>
        <text class="movie-meta movie-rating">{{item.rating}}分</text>
      </view>
    </view>
  </view>
</view>