.container {
  padding: 20rpx;
}

.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.page-count {
  font-size: 24rpx;
  color: #999;
}

.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}

.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  color: #ddd;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.empty-hint {
  font-size: 24rpx;
  color: #ccc;
  margin-top: 10rpx;
}

.movie-list {
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
}

.movie-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.movie-item:last-child {
  border-bottom: none;
}

.movie-rank {
  width: 50rpx;
  height: 50rpx;
  background: linear-gradient(135deg, #ff6b6b, #ff4757);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: bold;
  font-size: 24rpx;
  flex-shrink: 0;
}

.movie-poster {
  width: 100rpx;
  height: 140rpx;
  margin-left: 20rpx;
  border-radius: 8rpx;
  background: #eee;
}

.movie-info {
  flex: 1;
  margin-left: 20rpx;
}

.movie-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 350rpx;
}

.movie-meta {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-top: 4rpx;
}

.movie-rating {
  font-size: 26rpx;
  color: #ff6b6b;
  font-weight: bold;
}

.movie-actions {
  display: flex;
}

.action-btn {
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.action-btn.remove {
  background: #f5f5f5;
  color: #999;
}