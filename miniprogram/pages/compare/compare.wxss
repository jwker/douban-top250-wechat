.container {
  padding: 20rpx;
}

.date-selector {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 12rpx;
  padding: 30rpx 20rpx;
  margin-bottom: 20rpx;
}

.date-item {
  flex: 1;
  text-align: center;
}

.date-label {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 12rpx;
}

.date-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  padding: 16rpx 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
}

.vs {
  padding: 0 20rpx;
  font-size: 24rpx;
  color: #999;
  font-weight: bold;
}

.btn-compare {
  background: linear-gradient(135deg, #ff6b6b, #ff4757);
  color: #fff;
  border: none;
  border-radius: 44rpx;
  padding: 24rpx;
  font-size: 30rpx;
  margin-bottom: 30rpx;
}

.compare-result {
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
}

.tabs {
  display: flex;
  border-bottom: 1rpx solid #f0f0f0;
}

.tab {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
  color: #666;
  font-size: 28rpx;
}

.tab.active {
  color: #ff6b6b;
  border-bottom: 4rpx solid #ff6b6b;
}

.tab-count {
  font-size: 22rpx;
  margin-top: 4rpx;
  padding: 2rpx 12rpx;
  background: #f0f0f0;
  border-radius: 10rpx;
}

.tab.active .tab-count {
  background: #fff3f3;
  color: #ff6b6b;
}

.tab-content {
  padding: 20rpx;
}

.empty-tip {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 26rpx;
}

.movie-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  background: #fafafa;
  position: relative;
}

.movie-poster {
  width: 100rpx;
  height: 140rpx;
  border-radius: 8rpx;
  background: #eee;
}

.movie-info {
  flex: 1;
  margin-left: 20rpx;
}

.movie-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 380rpx;
}

.movie-rank-info {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

.change-badge {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: bold;
}

.change-badge.up {
  background: rgba(76, 175, 80, 0.1);
  color: #4CAF50;
}

.change-badge.down {
  background: rgba(244, 67, 54, 0.1);
  color: #f44336;
}