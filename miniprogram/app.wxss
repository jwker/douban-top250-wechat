page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

.container {
  padding: 20rpx;
}

.movie-item {
  display: flex;
  padding: 20rpx;
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.movie-rank {
  width: 60rpx;
  height: 60rpx;
  background: linear-gradient(135deg, #ff6b6b, #ff4757);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: bold;
  font-size: 28rpx;
  flex-shrink: 0;
}

.movie-poster {
  width: 120rpx;
  height: 160rpx;
  margin-left: 20rpx;
  border-radius: 8rpx;
  background: #eee;
}

.movie-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.movie-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.movie-meta {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 4rpx;
}

.movie-rating {
  color: #ff6b6b;
  font-weight: bold;
}

.btn-primary {
  background: linear-gradient(135deg, #ff6b6b, #ff4757);
  color: #fff;
  border: none;
  border-radius: 44rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
}

.btn-outline {
  border: 2rpx solid #ff6b6b;
  color: #ff6b6b;
  background: #fff;
  border-radius: 44rpx;
  padding: 16rpx 40rpx;
  font-size: 28rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin: 30rpx 0 20rpx;
  padding-left: 20rpx;
  border-left: 6rpx solid #ff6b6b;
}

.empty-tip {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}